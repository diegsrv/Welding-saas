import numpy as np

class WeldingEngine:

    def stress(self, force, surface):
        return force / max(surface, 0.0001)

    def heat(self, voltage, current, speed):
        return (voltage * current) / max(speed, 0.1)

    def thermal_zone(self, heat):
        return heat * 0.03

    def ai_score(self, force, surface, heat, speed):
        stress = self.stress(force, surface)

        score = 100 \
            - stress * 0.02 \
            + heat * 0.01 \
            - speed * 0.5

        return max(0, min(100, score))

    def recommendation(self, score):
        if score < 60:
            return "Increase heat or reduce speed"
        elif score < 80:
            return "Adjust parameters slightly"
        return "Optimal welding settings"
